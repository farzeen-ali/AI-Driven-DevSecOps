            "data": {
              "type": "tm.Process",
              "name": "Payment\nProcessor",
              "description": "",
              "outOfScope": false,
              "isTrustBoundary": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "handlesCardPayment": false,
              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "7a4898f9-ddc4-450f-8ad0-1885ca857215",
                  "title": "Database Injection / Unauthorized Write",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Tampering",
                  "description": "An attacker bypasses the Gateway's validation or exploits a vulnerability in the Payment Processor to inject malicious SQL, altering transaction amounts or statuses in the DB.",
                  "mitigation": "Use Parameterized Queries (Prepared Statements) and implement Database Least Privilege (the Processor should not have DROP or TRUNCATE permissions).",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 1,
                  "score": ""
                },
                {
                  "id": "2066cbda-1b25-41a3-a1e4-b37392c738bb",
                  "title": "Payment Data Leakage via Gateway Logs",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Information disclosure",
                  "description": "Sensitive Customer Data (e.g., PII or card tokens) is inadvertently logged by the API Gateway during the \"Request\" phase, exposing it to anyone with log access.",
                  "mitigation": "Implement Log Masking/Redaction at the Gateway level and ensure all data in transit is encrypted using mTLS within the trust boundary.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 2,
                  "score": ""
                },
                {
                  "id": "b6e995de-b8b4-4343-8f41-c19216b8fc0a",
                  "title": "Internal Service Impersonation",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Spoofing",
                  "description": "If the network is flat, a compromised sidecar or internal tool could spoof the \"Fintech API Gateway\" and send fraudulent \"Payment Requests\" directly to the Processor.",
                  "mitigation": "Implement Service-to-Service Authentication (e.g., SPIFFE/Spire or OAuth2 Client Credentials) to ensure the Processor only accepts requests from verified Gateways.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 3,
                  "score": ""
                },
                {
                  "id": "a1fe90e6-f7db-486f-8abc-2f450d9ba837",
                  "title": "Transaction Replay Attack",
                  "status": "Open",
                  "severity": "TBD",
                  "type": "Tampering",
                  "description": "An attacker captures a valid \"Payment Request\" and resubmits it multiple times to drain a customer's account or double-fund a wallet.",
                  "mitigation": "Implement Idempotency Keys for all payment endpoints. The Processor must check a cache to ensure a unique request_id is only processed once.",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 4,
                  "score": ""
                }
              ],
              "threatFrequency": {
                "spoofing": 1,
                "tampering": 2,
                "repudiation": 0,
                "informationDisclosure": 1,
